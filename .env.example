# Copy to .env and fill in. .env is gitignored — never commit real credentials.
NEO4J_URI=neo4j+s://<dbid>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<password>
NEO4J_DATABASE=neo4j

# For episode-narrative embeddings + presenting-complaint vector search
# (text-embedding-3-large, 3072-dim — matches episode_narrative_idx)
OPENAI_API_KEY=<openai-key>
